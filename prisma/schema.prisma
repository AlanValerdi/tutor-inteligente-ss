generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum StudyProfile {
  Visual
  Auditivo
  Kinestesico
}

enum AnxietyLevel {
  Bajo
  Medio
  Alto
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role          @default(STUDENT)
  studyProfile  StudyProfile?
  password      String?
  accounts      Account[]
  sessions      Session[]
  courses       Course[]      @relation("TeacherCourses")
  enrollments   Enrollment[]
  quizAttempts         QuizAttempt[]
  interactionSessions  InteractionSession[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id           String        @id @default(cuid())
  title        String
  description  String?
  enrollKey    String        @unique
  isPublished  Boolean       @default(false)
  teacherId    String
  teacher      User          @relation("TeacherCourses", fields: [teacherId], references: [id])
  enrollments          Enrollment[]
  topics               Topic[]
  quizzes              Quiz[]        // Course-level quizzes
  interactionSessions  InteractionSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Enrollment {
  id                String        @id @default(cuid())
  userId            String
  courseId          String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress          Int           @default(0)
  completedTopics   Int           @default(0)
  lastAccessedAt    DateTime?
  enrolledAt        DateTime      @default(now())
  
  // Learning profile data
  studyProfile      StudyProfile?
  anxietyLevel      AnxietyLevel  @default(Bajo)
  averageScore      Int           @default(0)
  
  // Profile scores (0-100 for each learning style)
  visualScore       Int           @default(0)
  auditivoScore     Int           @default(0)
  kinestesicoScore  Int           @default(0)
  
  // Anxiety metrics (stored as JSON arrays for last 10 sessions)
  tabSwitches       Json?         // Array of tab switch counts per session
  consecutiveClicks Json?         // Array of consecutive click counts
  missedClicks      Json?         // Array of missed click counts
  timePerQuestion   Json?         // Array of avg seconds per question
  idleTime          Json?         // Array of idle time in seconds
  scrollReversals   Json?         // Array of scroll reversal counts

  @@unique([userId, courseId])
}

model Topic {
  id                String             @id @default(cuid())
  title             String
  content           Json
  courseId          String
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizzes              Quiz[]
  completions          TopicCompletion[]
  interactionSessions  InteractionSession[]
  order             Int
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model TopicCompletion {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  isRead    Boolean  @default(false)
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, topicId])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum ResourceType {
  Video
  Audio
  Diapositiva
  JuegoInteractivo
  ImagenInteractiva
  Simulacion
  DiapositivaAdicional
}

model Quiz {
  id              String         @id @default(cuid())
  title           String
  description     String?
  // Quiz can be linked to a topic OR a course, but not both
  topicId         String?        // null = course-level quiz
  topic           Topic?         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  courseId        String?        // null = topic-level quiz
  course          Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions       Question[]
  attempts        QuizAttempt[]
  passingScore    Int            @default(70) // Percentage required to pass
  maxAttempts     Int?           // null = unlimited attempts
  timeLimit       Int?           // Time limit in minutes (null = no limit)
  shuffleQuestions Boolean       @default(false)
  isPublished     Boolean        @default(false)
  // For course-level quizzes, require completion of all topics?
  requireAllTopics Boolean       @default(false) // Only applicable if courseId is set
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([topicId])
  @@index([courseId])
}

model Question {
  id              String         @id @default(cuid())
  quizId          String
  quiz            Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type            QuestionType   @default(MULTIPLE_CHOICE)
  questionText    String         @db.Text
  imageUrl        String?        // Optional image for visual learners
  order           Int
  points          Int            @default(1)
  // For MULTIPLE_CHOICE: store as JSON array of {text, isCorrect}
  // For TRUE_FALSE: store as JSON {correctAnswer: true/false}
  // For SHORT_ANSWER: store as JSON {acceptedAnswers: []}
  options         Json
  explanation     String?        @db.Text // Shown after answering
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model QuizAttempt {
  id              String         @id @default(cuid())
  quizId          String
  quiz            Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  score           Int            // Percentage score (0-100)
  totalPoints     Int            // Total points earned
  maxPoints       Int            // Maximum possible points
  answers         Json           // Array of {questionId, selectedAnswer, isCorrect, pointsEarned}
  passed          Boolean        @default(false)
  timeSpent       Int?           // Time spent in seconds
  correctAnswers  Int?           // Total correct answers
  incorrectAnswers Int?          // Total incorrect answers
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
}

// ── Tracker ────────────────────────────────────────────────────────────────

// Una sesión por visita a un topic
model InteractionSession {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id])
  topicId           String
  topic             Topic                 @relation(fields: [topicId], references: [id])
  courseId          String
  course            Course                @relation(fields: [courseId], references: [id])
  sessionNumber     Int                   @default(1)

  // Métricas globales de ansiedad conductual
  totalTime         Float                 @default(0)   // segundos totales en el topic
  idleTime          Float                 @default(0)   // segundos sin actividad
  tabSwitches       Int                   @default(0)   // cambios de pestaña
  missedClicks      Int                   @default(0)   // clics en zonas no interactivas
  scrollReversals   Int                   @default(0)   // veces que scrolleó hacia arriba
  consecutiveClicks Int                   @default(0)   // clics rápidos consecutivos (<500ms)
  copyAttempts      Int                   @default(0)   // intentos de copiar texto de la página
  rightClickCount   Int                   @default(0)   // clics derechos (menú de contexto)
  windowBlurs       Int                   @default(0)   // pérdida de foco de ventana (alt-tab, cambio de app)
  anxietyLevel      AnxietyLevel?

  // Métricas de engagement del quiz (null en sesiones de topic)
  timePerQuestion   Json?                               // [{questionId, seconds}]
  attemptsPerQuestion Json?                             // [{questionId, attempts}]
  backNavigations   Int?                                // veces que regresó a pregunta anterior
  timeToFirstAnswer Json?                               // [{questionId, seconds}]

  resources         ResourceInteraction[]
  createdAt         DateTime              @default(now())

  @@index([userId])
  @@index([topicId])
  @@index([courseId])
}

// Una fila por tipo de recurso dentro de la sesión
model ResourceInteraction {
  id             String             @id @default(cuid())
  sessionId      String
  session        InteractionSession @relation(fields: [sessionId], references: [id])
  resourceType   ResourceType
  resourceId     String
  timeOnResource Float              @default(0)
  completed      Boolean            @default(false)

  // ── Video / Audio ──────────────────────────────────────────────
  percentageWatched    Float?
  timeWatched          Float?
  timesPaused          Int?
  timesReplayed        Int?

  // ── Diapositiva ────────────────────────────────────────────────
  totalSlides          Int?
  slidesViewed         Int?
  percentageViewed     Float?
  timesReviewed        Int?
  zoomUsed             Boolean?

  // ── Juego interactivo ──────────────────────────────────────────
  gameCompleted        Boolean?
  timesPlayed          Int?
  helpUsed             Boolean?
  correctResponses     Int?
  incorrectResponses   Int?
  completionPercent    Float?

  // ── Imagen interactiva ─────────────────────────────────────────
  zonesMarked          Int?
  visualAidsUsed       Boolean?
  attemptsImage        Int?
  correctIdentifications Int?

  // ── Simulación ─────────────────────────────────────────────────
  dataSelected         Json?
  simulationChanges    Int?
  attempts             Int?
  toolsUsed            Json?
  solutionPrecision    Float?

  // ── Diapositiva adicional ──────────────────────────────────────
  modifiedCaseResolved Boolean?
  visualSupportUsed    Boolean?
  reflectionTime       Float?
  errorsIdentified     Int?
  reflectionLevel      Int?

  createdAt            DateTime @default(now())

  @@index([sessionId])
  @@index([resourceType])
}
